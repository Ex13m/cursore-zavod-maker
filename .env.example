# Скопируй в .env (gitignored). Все ключи ОПЦИОНАЛЬНЫ — без них включается деградация.

# Ключ владельца: защищает одобрение/отгрузку/чат на портале (заголовок X-Zavod-Key).
# Придумай длинную случайную строку; тот же ключ введи кнопкой КЛЮЧ на пульте.
# Не задан — API открыт (только для локальной разработки!).
ZAVOD_ADMIN_KEY=

# Gumroad: публикация одобренного (Settings → Advanced → Applications → token)
GUMROAD_ACCESS_TOKEN=

# Anthropic: AI-инженер в цех-чате (console.anthropic.com)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Replicate: FLUX-спрайты для image-курсоров (replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=
# REPLICATE_MODEL=black-forest-labs/flux-schnell

# Resend: утреннее письмо (resend.com)
RESEND_API_KEY=
EMAIL_TO=ex333m@gmail.com
EMAIL_FROM=CURSOR ZAVOD <onboarding@resend.dev>

# Куда ведёт ссылка из письма (после деплоя — URL Netlify-сайта)
PORTAL_URL=http://localhost:5173

# Порт локального dev API
PORT=8787

# Необязательный внешний источник тренд-сигналов (JSON)
TRENDS_SIGNAL_URL=

# --- Антибан-политика отгрузки (защита от бана площадки за спам-поведение) ---
PUBLISH_DAILY_MAX=6      # потолок публикаций в сутки после разогрева
PUBLISH_WARMUP_DAYS=7    # за сколько дней разогреть аккаунт от 1 до потолка
PUBLISH_MIN_GAP=45       # мин. пауза между заливами, сек
PUBLISH_MAX_GAP=180      # макс. пауза между заливами, сек
